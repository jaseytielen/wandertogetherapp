      <div class="log-item"><div class="log-dot" style="background:#5aa85a"></div><div><div class="log-text">🇬🇷 Kreta — prijs gedaald met €20, nu <strong>€155</strong></div><div class="log-time">Gisteren, 17:32</div></div></div>
      <div class="log-item"><div class="log-dot" style="background:#e8a030"></div><div><div class="log-text">🇪🇸 Ibiza — prijs gestegen met €30. Vroeg boeken aanbevolen.</div><div class="log-time">2 dagen geleden</div></div></div>
      <div class="log-item"><div class="log-dot" style="background:#5080c8"></div><div><div class="log-text">🍼 Tip: Alcúdia (Mallorca) heeft ondiep water — ideaal voor baby</div><div class="log-time">3 dagen geleden</div></div></div>
    </div>
  </div>
</div>

<div class="bottom-nav">
  <button class="bnav-btn active" id="bn-0" onclick="navTo('destinations',0)"><span class="bnav-ico">🗺</span><span class="bnav-lbl">Bestemmingen</span></button>
  <button class="bnav-btn" id="bn-1" onclick="navTo('prices',1)"><span class="bnav-ico">📊</span><span class="bnav-lbl">Prijzen</span></button>
  <button class="bnav-btn" id="bn-2" onclick="navTo('alerts',2)"><span class="bnav-ico">🔔</span><span class="bnav-lbl">Alerts</span></button>
</div>

<div class="toast" id="toast">✓ Opgeslagen</div>

<script>
const DESTINATIONS = [
