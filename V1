      <div class="toggle-item"><div><div class="ti-label">Prijsdaling hotels</div><div class="ti-sub">Bij daling van meer dan 15%</div></div><button class="toggle on" onclick="this.classList.toggle('on')"></button></div>
      <div class="toggle-item"><div><div class="ti-label">Speciale evenementen</div><div class="ti-sub">Festivals, markten, seizoenen</div></div><button class="toggle on" onclick="this.classList.toggle('on')"></button></div>
      <div class="toggle-item"><div><div class="ti-label">Reisadvies-updates</div><div class="ti-sub">Veiligheid, visa, gezondheid</div></div><button class="toggle on" onclick="this.classList.toggle('on')"></button></div>
    </div>
    <div class="form-card">
      <div class="form-title">Recente alerts</div>
      <div class="form-sub">Laatste meldingen voor jullie bestemmingen</div>
