        <div class="field"><label class="field-label">Alert onder (EU)</label><input class="field-input" type="number" id="thresh-eu" placeholder="€ 150"></div>
        <div class="field"><label class="field-label">Alert onder (ver)</label><input class="field-input" type="number" id="thresh-long" placeholder="€ 700"></div>
      </div>
      <button class="save-btn" onclick="saveSettings()">Opslaan en activeren</button>
    </div>
    <div class="form-card">
      <div class="form-title">Welke alerts?</div>
      <div class="form-sub">Zet aan wat relevant is voor jullie</div>
