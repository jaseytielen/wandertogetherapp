    </div>
  </div>
</div>

<!-- ALERTS -->
<div class="page" id="page-alerts">
  <div class="alerts-page">
    <div class="form-card">
      <div class="form-title">Jullie e-mailadressen</div>
      <div class="form-sub">Beide adressen ontvangen elke alert automatisch</div>
      <div class="field"><label class="field-label">Jouw e-mail</label><input class="field-input" type="email" id="email1" placeholder="jij@email.com"></div>
      <div class="field"><label class="field-label">Lieke haar e-mail</label><input class="field-input" type="email" id="email2" placeholder="lieke@email.com"></div>
