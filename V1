function trendClass(t) { return t === 'down' ? 'trend-down' : t === 'up' ? 'trend-up' : 'trend-flat'; }
function trendLabel(t, d) { return t === 'down' ? `↓ €${d} goedkoper` : t === 'up' ? `↑ €${d} duurder` : '→ stabiel'; }

function renderCard(d, isDream) {
  const priceHtml = isDream
    ? `<div class="card-price" style="color:var(--muted);font-size:20px;">droomdoel</div><span class="price-trend trend-flat" style="color:var(--muted);">± €${d.iata === 'MLE' ? 1200 : 180}</span>`
    : `<div class="card-price" data-iata="${d.iata}">€${d.price}</div><span class="price-trend ${trendClass(d.trend)}">${trendLabel(d.trend, d.delta)}</span><div class="live-badge"><span class="live-dot"></span> live</div>`;

  return `
  <div class="dest-card" onclick="expand(this)">
    <div class="card-face">
      <div class="card-left">
        <span class="card-flag">${d.flag}</span>
        <div class="card-name">${d.name}</div>
        <div class="card-region">${d.region}</div>
        <div class="card-badges">${d.badges.map(b => `<span class="badge${b.startsWith('🍼') ? ' badge-baby' : ''}">${b}</span>`).join('')}</div>
      </div>
      <div class="card-right">
        <div class="card-price-sub">v/v per persoon</div>
        ${priceHtml}
      </div>
    </div>
    <div class="card-chevron"><span class="chevron-icon">▾</span></div>
    <div class="card-body">
      <div class="card-body-inner">
        <div class="meta-strip">
          <div class="meta-item"><div class="meta-lbl">Vlucht</div><div class="meta-val">${d.flight}</div></div>
          <div class="meta-item"><div class="meta-lbl">Hotel/nacht</div><div class="meta-val">${d.hotel}</div></div>
          <div class="meta-item"><div class="meta-lbl">Visum</div><div class="meta-val">${d.visum}</div></div>
          <div class="meta-item"><div class="meta-lbl">Week budget</div><div class="meta-val">${d.budget}</div></div>
        </div>
        <div class="spots-label">Hotspots</div>
        <div class="spots-row">${d.spots.map(s => `<span class="spot">${s}</span>`).join('')}</div>
        <div class="book-row">
          <a class="book-link bl-sky" href="https://www.skyscanner.nl/flights/${d.sky}/" target="_blank"><span class="bl-ico">✈</span>Skyscanner</a>
          <a class="book-link bl-bkg" href="https://www.booking.com/searchresults.html?ss=${d.bkg}" target="_blank"><span class="bl-ico">🏨</span>Booking</a>
          <a class="book-link bl-air" href="https://www.airbnb.nl/s/${d.air}/homes" target="_blank"><span class="bl-ico">🏠</span>Airbnb</a>
        </div>
      </div>
    </div>
  </div>`;
}

function renderPriceRow(d) {
  return `<div class="price-item">
    <div class="pi-left"><span class="pi-flag">${d.flag}</span><div><div class="pi-name">${d.name}</div><div class="pi-route">AMS → ${d.iata}</div></div></div>
    <div class="pi-right"><div class="pi-price ${trendClass(d.trend)}" data-price-iata="${d.iata}">€${d.price}</div><div class="pi-trend ${trendClass(d.trend)}">${trendLabel(d.trend, d.delta)}</div></div>
  </div>`;
}

document.getElementById('destList').innerHTML = DESTINATIONS.map(d => renderCard(d, false)).join('');
document.getElementById('dreamList').innerHTML = DREAMS.map(d => renderCard(d, true)).join('');
document.getElementById('priceList').innerHTML = DESTINATIONS.map(d => renderPriceRow(d)).join('');

function expand(card) {
  const isOpen = card.classList.contains('open');
  document.querySelectorAll('.dest-card.open').forEach(c => c.classList.remove('open'));
  if (!isOpen) card.classList.add('open');
}

const PAGE_DATA = {
  destinations: { title: 'Jullie<br><em>droomreizen</em>', sub: 'Zomer 2026 · 2 reizigers + baby ☀️' },
  prices:        { title: 'Prijs<br><em>radar</em>',        sub: 'Live vluchprijzen vanuit Amsterdam' },
  alerts:        { title: 'Alert<br><em>instellingen</em>', sub: 'Ontvang meldingen op maat' },
};
const PAGE_KEYS = ['destinations','prices','alerts'];

function navTo(page, idx) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.querySelectorAll('.pill-btn').forEach((b,i) => b.classList.toggle('active', i === idx));
  document.querySelectorAll('.bnav-btn').forEach((b,i) => b.classList.toggle('active', i === idx));
  document.getElementById('mainTitle').innerHTML = PAGE_DATA[page].title;
  document.getElementById('mainSub').textContent = PAGE_DATA[page].sub;
  window.scrollTo(0,0);
}

function saveSettings() {
  const k = document.getElementById('apikey').value.trim();
  const e1 = document.getElementById('email1').value.trim();
  const e2 = document.getElementById('email2').value.trim();
  if (k)  localStorage.setItem('wt_key', k);
  if (e1) localStorage.setItem('wt_e1', e1);
  if (e2) localStorage.setItem('wt_e2', e2);
  const thresh = document.getElementById('thresh-eu').value;
  if (thresh) localStorage.setItem('wt_thresh', thresh);
  showToast('✓ Opgeslagen! Prijzen worden ververst.');
  if (k) fetchLivePrices(k);
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ── RAPIDAPI LIVE PRICE FETCH ──
async function fetchLivePrices(apiKey) {
  const today = new Date();
  const travelDate = '2026-07-15';

  for (const d of DESTINATIONS) {
    try {
      const res = await fetch(
        `https://skyscanner50.p.rapidapi.com/api/v1/searchFlights?origin=AMS&destination=${d.iata}&date=${travelDate}&adults=2&currency=EUR&locale=nl-NL`,
        {
          headers: {
            'X-RapidAPI-Key': apiKey,
            'X-RapidAPI-Host': 'skyscanner50.p.rapidapi.com'
          }
        }
      );
      if (!res.ok) continue;
      const json = await res.json();
      const raw = json?.data?.itineraries?.[0]?.price?.raw;
      if (raw && raw > 0) {
        const price = '€' + Math.round(raw);
        document.querySelectorAll(`[data-iata="${d.iata}"]`).forEach(el => { el.textContent = price; });
        document.querySelectorAll(`[data-price-iata="${d.iata}"]`).forEach(el => { el.textContent = price; });
      }
    } catch (err) { /* silently keep fallback price */ }
  }
}

// Restore on load
window.addEventListener('load', () => {
  const k = localStorage.getItem('wt_key');
  const e1 = localStorage.getItem('wt_e1');
  const e2 = localStorage.getItem('wt_e2');
  const th = localStorage.getItem('wt_thresh');
  if (k)  { document.getElementById('apikey').value = k; fetchLivePrices(k); }
  if (e1) document.getElementById('email1').value = e1;
  if (e2) document.getElementById('email2').value = e2;
  if (th) document.getElementById('thresh-eu').value = th;
});
